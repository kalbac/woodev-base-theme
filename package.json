{
  "name": "woodev-base-theme-dev",
  "private": true,
  "type": "module",
  "description": "Dev tooling for the Woodev Base WordPress theme.",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "tokens": "node scripts/build-tokens.mjs",
    "icons": "node scripts/copy-icons.mjs",
    "packs": "node scripts/build-pack-entries.mjs",
    "dev": "npm run tokens && npm run packs && vite",
    "build": "npm run tokens && npm run packs && vite build",
    "test:js": "vitest run",
    "lint:js": "eslint .",
    "format": "prettier --check .",
    "e2e": "playwright test",
    "e2e:dev": "playwright test --config=playwright.dev.config.mjs",
    "wp:start": "wp-env start",
    "wp:stop": "wp-env stop",
    "wp:test:start": "wp-env start --config=.wp-env.test.json",
    "wp:test:stop": "wp-env stop --config=.wp-env.test.json",
    "wp:dev-mode:start": "wp-env start --config=.wp-env.dev-mode.json",
    "wp:dev-mode:stop": "wp-env stop --config=.wp-env.dev-mode.json",
    "test:integration:install": "wp-env run cli --config=.wp-env.test.json --env-cwd=wp-content/woodev-tests composer install",
    "test:integration": "wp-env run cli --config=.wp-env.test.json --env-cwd=wp-content/woodev-tests vendor/bin/phpunit -c phpunit.xml.dist",
    "test:integration:dev": "wp-env run cli --config=.wp-env.test.json --env-cwd=wp-content/woodev-tests vendor/bin/phpunit -c phpunit.dev.xml.dist"
  },
  "devDependencies": {
    "@alpinejs/focus": "^3.15.12",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@wordpress/env": "^11.11.0",
    "alpinejs": "^3.15.12",
    "basecoat-css": "1.0.2",
    "eslint": "^10.7.0",
    "lucide-static": "^1.25.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
